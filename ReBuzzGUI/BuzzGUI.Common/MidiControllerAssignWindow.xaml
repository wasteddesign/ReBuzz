<Window x:Class="BuzzGUI.Common.MidiControllerAssignWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BuzzGUI.Common"
        mc:Ignorable="d"
        WindowStyle="ToolWindow"
        TextOptions.TextFormattingMode="{Binding TextFormattingMode}"
        Style="{DynamicResource ThemeWindowStyle}" ResizeMode="NoResize"
        Title="Midi Controller" Height="237" Width="313">
    <Grid Margin="4" x:Name="mainGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition Height="30"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="Move MIDI controller to select it" Grid.ColumnSpan="2" Margin="4"/>
        <TextBlock Grid.Row="1" Text="Bind To" Margin="4"/>
        <ComboBox x:Name="cbBindList" Grid.Row="1" Grid.Column="1" ItemsSource="{Binding DropDownSelection}" Margin="4"></ComboBox>
        <TextBlock Grid.Row="2" Text="Controller" Margin="4"/>
        <TextBox x:Name="tbController" Grid.Row="2" Grid.Column="1" Text="{Binding MidiController, Mode=TwoWay}" HorizontalAlignment="Left" Width="50" Margin="4"/>
        <TextBlock Grid.Row="3" Text="Channel" Margin="4"/>
        <TextBox x:Name="tbChannel" Grid.Row="3" Grid.Column="1" Text="{Binding MidiChannel, Mode=TwoWay}" HorizontalAlignment="Left" Width="50" Margin="4"/>
        <TextBlock Grid.Row="4" Text="Value" Margin="4"/>
        <TextBox x:Name="tbValue" Grid.Row="4" Grid.Column="1" Text="{Binding MidiValue, Mode=TwoWay}" HorizontalAlignment="Left" Width="50" Margin="4"/>
        <TextBlock x:Name="tblName" Grid.Row="5" Text="Name" Margin="4"/>
        <TextBox x:Name="tbName" Grid.Row="5" Grid.Column="1" Text="{Binding ControllerName, Mode=TwoWay}" HorizontalAlignment="Left" Width="200" Margin="4"/>
        <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="btOk" IsDefault="True" Margin ="4" Height ="20" Width="60" VerticalAlignment="Bottom" Content="Ok" IsEnabled="{Binding IsInputValid}"></Button>
            <Button Name="btCance" Margin ="4" Height ="20" Width="60" VerticalAlignment="Bottom" IsCancel="true" Content="Cancel"></Button>
        </StackPanel>
    </Grid>
</Window>