<UserControl x:Class="ReBuzz.InfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:mdxam="clr-namespace:MdXaml;assembly=MdXaml"
             xmlns:local="clr-namespace:ReBuzz"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" VerticalAlignment ="Stretch">

    <Grid >
        <TabControl>
            <TabItem Header="Info">
                <mdxam:MarkdownScrollViewer MarkdownStyle="{DynamicResource MarkdownScrollViewerStyle1}" xml:space="preserve" x:Name="msv"/>
                
            </TabItem>
            <TabItem Header="Edit">
                <TextBox Name="tbInfo" Style="{DynamicResource TextBoxStyle1}" AcceptsReturn="True" TextWrapping="Wrap"/>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>
